{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.paper-collage.dev/project.schema.json",
  "title": "Paper Collage Video Project",
  "type": "object",
  "required": ["schemaVersion", "slug", "title", "video", "theme", "audio", "scenes"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "title": {"type": "string", "minLength": 1},
    "plan": {"$ref": "#/$defs/creativePlan"},
    "video": {
      "type": "object",
      "required": ["width", "height", "fps", "transitionFrames"],
      "properties": {
        "width": {"type": "integer", "minimum": 320},
        "height": {"type": "integer", "minimum": 320},
        "fps": {"type": "number", "exclusiveMinimum": 0},
        "transitionFrames": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "theme": {"type": "object"},
    "voice": {"type": "object"},
    "audio": {"type": "object"},
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "eyebrow", "tailFrames", "background", "narration", "layers", "subtitles"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string"},
          "eyebrow": {"type": "string"},
          "tailFrames": {"type": "integer", "minimum": 0},
          "background": {"type": "string", "minLength": 1},
          "narration": {
            "type": "object",
            "required": ["src", "startFrame", "durationSeconds", "text"],
            "properties": {
              "src": {"type": "string", "minLength": 1},
              "startFrame": {"type": "integer", "minimum": 0},
              "durationSeconds": {"type": "number", "exclusiveMinimum": 0},
              "text": {"type": "string"}
            },
            "additionalProperties": false
          },
          "layers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "src", "role", "x", "bottom", "width", "z", "delay", "enterFrom"],
              "properties": {
                "id": {"type": "string"},
                "src": {"type": "string"},
                "role": {"enum": ["primary", "secondary", "tertiary"]},
                "x": {"type": "number"},
                "bottom": {"type": "number"},
                "width": {"type": "number", "exclusiveMinimum": 0},
                "z": {"type": "integer"},
                "delay": {"type": "integer", "minimum": 0},
                "enterFrom": {"enum": ["left", "right", "bottom"]}
              },
              "additionalProperties": false
            }
          },
          "subtitles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to", "text"],
              "properties": {
                "from": {"type": "integer", "minimum": 0},
                "to": {"type": "integer", "minimum": 1},
                "text": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullablePositiveNumber": {
      "oneOf": [
        {"type": "number", "exclusiveMinimum": 0},
        {"type": "null"}
      ]
    },
    "nullablePositiveInteger": {
      "oneOf": [
        {"type": "integer", "minimum": 1},
        {"type": "null"}
      ]
    },
    "creativePlan": {
      "type": "object",
      "required": ["schemaVersion", "slug", "status", "inputMode", "requested", "resolved", "updatedAt"],
      "properties": {
        "schemaVersion": {"const": 1},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "status": {"enum": ["pending", "resolved"]},
        "inputMode": {"enum": ["none", "duration-only", "scenes-only", "both"]},
        "requested": {
          "type": "object",
          "required": ["durationSeconds", "sceneCount"],
          "properties": {
            "durationSeconds": {"$ref": "#/$defs/nullablePositiveNumber"},
            "sceneCount": {"$ref": "#/$defs/nullablePositiveInteger"}
          },
          "additionalProperties": false
        },
        "resolved": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["durationSeconds", "sceneCount", "estimatedNarrationSeconds", "rationale", "resolvedAt"],
              "properties": {
                "durationSeconds": {"type": "number", "exclusiveMinimum": 0},
                "sceneCount": {"type": "integer", "minimum": 1},
                "estimatedNarrationSeconds": {"$ref": "#/$defs/nullablePositiveNumber"},
                "rationale": {"type": "string", "minLength": 1},
                "resolvedAt": {"type": "string", "format": "date-time"}
              },
              "additionalProperties": false
            }
          ]
        },
        "updatedAt": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  }
}
