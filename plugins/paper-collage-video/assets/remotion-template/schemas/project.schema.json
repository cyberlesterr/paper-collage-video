{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.paper-collage.dev/project.schema.json",
  "title": "Paper Collage Video Project",
  "type": "object",
  "required": ["schemaVersion", "slug", "title", "video", "theme", "audio", "scenes"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "title": {"type": "string", "minLength": 1},
    "plan": {"$ref": "#/$defs/creativePlan"},
    "quality": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {"enum": ["required", "advisory", "off"]},
        "minimumAssetScale": {"type": "number", "exclusiveMinimum": 0, "maximum": 2}
      },
      "additionalProperties": false
    },
    "video": {
      "type": "object",
      "required": ["width", "height", "fps", "transitionFrames"],
      "properties": {
        "width": {"type": "integer", "minimum": 320},
        "height": {"type": "integer", "minimum": 320},
        "fps": {"type": "number", "exclusiveMinimum": 0},
        "transitionFrames": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "theme": {
      "type": "object",
      "properties": {
        "fontFamily": {"type": "string", "minLength": 1},
        "fontFile": {"type": "string", "minLength": 1}
      }
    },
    "voice": {"type": "object"},
    "audio": {
      "type": "object",
      "properties": {
        "mastering": {
          "type": "object",
          "required": ["targetLufs", "toleranceLufs", "truePeakDbtp"],
          "properties": {
            "targetLufs": {"type": "number"},
            "toleranceLufs": {"type": "number", "exclusiveMinimum": 0},
            "truePeakDbtp": {"type": "number"}
          },
          "additionalProperties": false
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "eyebrow", "tailFrames", "background", "narration", "layers", "subtitles"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "label": {"type": "string"},
          "eyebrow": {"type": "string"},
          "tailFrames": {"type": "integer", "minimum": 0},
          "background": {"type": "string", "minLength": 1},
          "environmentLayers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "src", "depth", "z"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "src": {"type": "string", "minLength": 1},
                "depth": {"type": "number", "minimum": -1, "maximum": 1},
                "z": {"type": "integer"},
                "x": {"type": "number"},
                "y": {"type": "number"},
                "width": {"type": "number", "exclusiveMinimum": 0},
                "opacity": {"type": "number", "minimum": 0, "maximum": 1}
              },
              "additionalProperties": false
            }
          },
          "camera": {
            "type": "object",
            "properties": {
              "preset": {"enum": ["push", "pull", "pan-left", "pan-right", "static"]},
              "intensity": {"type": "number", "minimum": 0, "maximum": 3},
              "keyframes": {
                "type": "array",
                "minItems": 2,
                "items": {
                  "type": "object",
                  "required": ["at"],
                  "properties": {
                    "at": {"type": "number", "minimum": 0, "maximum": 1},
                    "x": {"type": "number"},
                    "y": {"type": "number"},
                    "zoom": {"type": "number", "exclusiveMinimum": 0}
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          "transition": {
            "type": "object",
            "properties": {
              "type": {"enum": ["fade", "none"]},
              "durationFrames": {"type": "integer", "minimum": 0}
            },
            "additionalProperties": false
          },
          "narration": {
            "type": "object",
            "required": ["src", "startFrame", "durationSeconds", "text"],
            "properties": {
              "src": {"type": "string", "minLength": 1},
              "timingSrc": {"type": "string", "minLength": 1},
              "startFrame": {"type": "integer", "minimum": 0},
              "durationSeconds": {"type": "number", "exclusiveMinimum": 0},
              "text": {"type": "string"}
            },
            "additionalProperties": false
          },
          "layers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "src", "role", "x", "bottom", "width", "z", "delay", "enterFrom"],
              "properties": {
                "id": {"type": "string"},
                "src": {"type": "string"},
                "role": {"enum": ["primary", "secondary", "tertiary"]},
                "x": {"type": "number"},
                "bottom": {"type": "number"},
                "width": {"type": "number", "exclusiveMinimum": 0},
                "z": {"type": "integer"},
                "delay": {"type": "integer", "minimum": 0},
                "delaySeconds": {"type": "number", "minimum": 0},
                "enterFrom": {"enum": ["left", "right", "bottom"]},
                "motion": {
                  "type": "object",
                  "properties": {
                    "idle": {"enum": ["float", "breathe", "grind", "drift", "still"]},
                    "intensity": {"type": "number", "minimum": 0, "maximum": 3},
                    "cycleSeconds": {"type": "number", "exclusiveMinimum": 0},
                    "phase": {"type": "number"},
                    "enterDurationSeconds": {"type": "number", "exclusiveMinimum": 0}
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          },
          "subtitles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["from", "to", "text"],
              "properties": {
                "from": {"type": "integer", "minimum": 0},
                "to": {"type": "integer", "minimum": 1},
                "text": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "audioEvents": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "src", "volume"],
              "properties": {
                "id": {"type": "string", "minLength": 1},
                "src": {"type": "string", "minLength": 1},
                "volume": {"type": "number", "minimum": 0},
                "fromFrame": {"type": "integer", "minimum": 0},
                "atSeconds": {"type": "number", "minimum": 0}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nullablePositiveNumber": {
      "oneOf": [
        {"type": "number", "exclusiveMinimum": 0},
        {"type": "null"}
      ]
    },
    "nullablePositiveInteger": {
      "oneOf": [
        {"type": "integer", "minimum": 1},
        {"type": "null"}
      ]
    },
    "creativePlan": {
      "type": "object",
      "required": ["schemaVersion", "slug", "status", "inputMode", "requested", "resolved", "updatedAt"],
      "properties": {
        "schemaVersion": {"const": 1},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "status": {"enum": ["pending", "resolved"]},
        "inputMode": {"enum": ["none", "duration-only", "scenes-only", "both"]},
        "requested": {
          "type": "object",
          "required": ["durationSeconds", "sceneCount"],
          "properties": {
            "durationSeconds": {"$ref": "#/$defs/nullablePositiveNumber"},
            "sceneCount": {"$ref": "#/$defs/nullablePositiveInteger"}
          },
          "additionalProperties": false
        },
        "resolved": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "required": ["durationSeconds", "sceneCount", "estimatedNarrationSeconds", "rationale", "resolvedAt"],
              "properties": {
                "durationSeconds": {"type": "number", "exclusiveMinimum": 0},
                "sceneCount": {"type": "integer", "minimum": 1},
                "estimatedNarrationSeconds": {"$ref": "#/$defs/nullablePositiveNumber"},
                "rationale": {"type": "string", "minLength": 1},
                "resolvedAt": {"type": "string", "format": "date-time"}
              },
              "additionalProperties": false
            }
          ]
        },
        "updatedAt": {"type": "string", "format": "date-time"}
      },
      "additionalProperties": false
    }
  }
}
