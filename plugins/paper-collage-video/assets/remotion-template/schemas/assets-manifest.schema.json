{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.paper-collage.dev/assets-manifest.schema.json",
  "title": "Paper Collage Generated Asset Manifest",
  "type": "object",
  "required": ["schemaVersion", "projectSlug", "assets"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 3},
    "projectSlug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assetId", "capability", "file", "provider", "adapter", "requestFingerprint", "reusedFrom", "sha256", "sizeBytes", "recordedAt", "request", "compositionBinding", "familyFingerprint"],
        "properties": {
          "assetId": {"type": "string"},
          "capability": {"enum": ["text", "image", "voice"]},
          "file": {"type": "string"},
          "provider": {"type": "string"},
          "adapter": {"enum": ["host", "command", "manual"]},
          "tool": {"type": ["string", "null"]},
          "model": {"type": ["string", "null"]},
          "externalId": {"type": ["string", "null"]},
          "requestFingerprint": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "reusedFrom": {"type": ["string", "null"]},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "sizeBytes": {"type": "integer", "minimum": 1},
          "recordedAt": {"type": "string", "format": "date-time"},
          "request": {"type": "object"},
          "compositionBinding": {"type": ["object", "null"]},
          "familyFingerprint": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
