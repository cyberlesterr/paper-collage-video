{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.paper-collage.dev/asset-request.schema.json",
  "title": "Paper Collage Provider Asset Request",
  "type": "object",
  "required": ["schemaVersion", "projectSlug", "assetId", "capability", "output"],
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"const": 1},
    "projectSlug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "assetId": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "capability": {"enum": ["text", "image", "voice"]},
    "output": {"type": "string", "minLength": 1},
    "prompt": {"type": "string"},
    "text": {"type": "string"},
    "voiceId": {"type": "string"},
    "model": {"type": "string"},
    "settings": {"type": "object"}
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {"properties": {"capability": {"const": "text"}}},
      "then": {"required": ["prompt"]}
    },
    {
      "if": {"properties": {"capability": {"const": "image"}}},
      "then": {"required": ["prompt"]}
    },
    {
      "if": {"properties": {"capability": {"const": "voice"}}},
      "then": {"required": ["text"]}
    }
  ]
}
