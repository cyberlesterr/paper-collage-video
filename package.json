{
  "name": "paper-collage-video-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:rasterize": "node scripts/rasterize-assets.mjs",
    "assets:process-sheet": "node scripts/process-character-sheet.mjs",
    "provider:status": "node scripts/provider-status.mjs",
    "provider:select": "node scripts/provider-select.mjs",
    "provider:run": "node scripts/provider-run.mjs",
    "provider:record": "node scripts/provider-record.mjs",
    "project:new": "node scripts/project-new.mjs",
    "project:status": "node scripts/project-status.mjs",
    "project:handoff-check": "node scripts/project-handoff-check.mjs",
    "project:checkpoint": "node scripts/project-checkpoint.mjs",
    "project:review-sync": "node scripts/project-review-sync.mjs",
    "project:advance": "node scripts/project-advance.mjs",
    "project:assets-ready": "node scripts/project-assets-ready.mjs",
    "project:sync": "node scripts/project-sync.mjs",
    "project:validate": "node scripts/project-validate.mjs",
    "project:preview": "node scripts/project-render.mjs preview",
    "project:render": "node scripts/project-render.mjs render",
    "project:report": "node scripts/project-report.mjs",
    "doctor": "node scripts/project-doctor.mjs",
    "plugin:sync": "node scripts/sync-plugin-package.mjs",
    "dev": "remotion studio src/index.ts --props=projects/tang-demo/project.json",
    "check": "tsc --noEmit",
    "bundle": "remotion bundle src/index.ts",
    "render": "npm run project:render -- tang-demo",
    "render:preview": "npm run project:preview -- tang-demo",
    "render:frame": "remotion still src/index.ts Paper-Collage out/replica-preview-frame.png --props=projects/tang-demo/project.json --frame=470",
    "render:prototype": "remotion render src/index.ts Tang-Paper-Cutout-Prototype out/tang-paper-cutout-prototype.mp4 --scale=0.5 --concurrency=8",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "@remotion/cli": "4.0.489",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.489"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "sharp": "0.35.3",
    "typescript": "5.9.3"
  }
}
